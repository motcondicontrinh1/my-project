# Copy this file to `.env.local` (gitignored) and fill in real values.
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# HiveMQ Cloud WebSocket URL — note port 8884 + "/mqtt" path for WSS.
VITE_MQTT_URL=wss://xxxxxxxxxxxxxxxxxxxxxxxx.s1.eu.hivemq.cloud:8884/mqtt
VITE_MQTT_USERNAME=your-mqtt-user
VITE_MQTT_PASSWORD=your-mqtt-password

# Must match TOPIC_PREFIX in firmware/door_controller/secrets.h
VITE_TOPIC_PREFIX=home/hoa-door-7f3a

# Simple UI gate (4-6 digits). NOT real security — see plan.
VITE_UI_PIN=1234
