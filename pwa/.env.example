# Copy this file to `.env.local` (gitignored) and fill in real values.

# Cloudflare Worker URL — handles PIN auth and MQTT publish server-side.
# MQTT credentials are stored as Worker secrets, never in this file.
VITE_WORKER_URL=https://door-control-worker.<your-subdomain>.workers.dev

# HiveMQ Cloud WebSocket URL for subscribe-only (status, heartbeat, diagnostics).
# Use a read-only credential or the same credential — Worker handles publish.
VITE_MQTT_URL=wss://24a213735d70437ab22918054725c865.s1.eu.hivemq.cloud:8884/mqtt
VITE_MQTT_USERNAME=your-mqtt-user
VITE_MQTT_PASSWORD=your-mqtt-password

# Must match TOPIC_PREFIX in worker/wrangler.toml AND firmware/door_controller/secrets.h
VITE_TOPIC_PREFIX=h/b7e3f1a29c4d8e05
